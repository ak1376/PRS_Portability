        # single big sim (sid=0, rep=0) tree + phenotype
        f"{SIM_BASEDIR}/0/rep0/tree_sequence.trees",
        f"{SIM_BASEDIR}/0/rep0/phenotype.pkl",
        # VAE inputs
        f"{GENO_BASEDIR}/all_individuals.npy",
        f"{GENO_BASEDIR}/meta.pkl",
        # VAE training outputs for all parameter combinations
        expand(f"{VAE_BASEDIR}/{{param_id}}/genotype_vae.pt", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/vae_losses.csv", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/vae_loss_curves.png", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/latent_pca_by_population.png", param_id=PARAM_IDS),
        # # VAE LD evaluation outputs for all parameter combinations
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_comparison_summary.txt", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_scatter_orig_vs_recon.png", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_difference_hist.png", param_id=PARAM_IDS),
        # LD diagnostics with heatmaps and decay plots
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_diagnostics/ld_metrics.json", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_diagnostics/ld_decay.png", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_diagnostics/ld_heatmap_real.png", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/ld_diagnostics/ld_heatmap_recon.png", param_id=PARAM_IDS),
        # Genotype reconstruction diagnostics
        expand(f"{VAE_BASEDIR}/{{param_id}}/genotype_diagnostics/genotype_metrics.json", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/genotype_diagnostics/genotype_heatmaps.png", param_id=PARAM_IDS),
        expand(f"{VAE_BASEDIR}/{{param_id}}/genotype_diagnostics/reconstruction_metrics.png", param_id=PARAM_IDS)

##############################################################################
# RULE simulate – one big simulation for VAE                                 #
##############################################################################
rule simulate:
    input:
        cfg = EXP_CFG
    output:
        sfs       = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/SFS.pkl",
        params    = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/sampled_params.pkl",
        tree      = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/tree_sequence.trees",
        fig       = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/demes.png",
        meta      = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/bgs.meta.json",
        trait     = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/effect_sizes.pkl",
        phenotype = f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/phenotype.pkl",
        done      = protected(f"{SIM_BASEDIR}/{{sid}}/rep{{rep}}/.done"),
    params:
        sim_dir = SIM_BASEDIR,
        model   = MODEL
    threads: 1
    shell:
        r"""
        set -euo pipefail

        python "{SIM_SCRIPT}" \
          --simulation-dir "{SIM_BASEDIR}/{wildcards.sid}/rep{wildcards.rep}" \
          --experiment-config "{input.cfg}" \
          --model-type "{params.model}" \
          --simulation-number {wildcards.sid} \
          --replicate {wildcards.rep} \
          --output-dir "{SIM_BASEDIR}/{wildcards.sid}/rep{wildcards.rep}"

        test -f "{output.meta}"
        touch "{output.done}"
        """

##############################################################################
# RULE build_genotypes_for_vae – .trees -> all_individuals.npy + meta.pkl   #
##############################################################################
rule build_genotypes_for_vae:
    input:
        tree   = f"{SIM_BASEDIR}/0/rep0/tree_sequence.trees",
        pheno  = f"{SIM_BASEDIR}/0/rep0/phenotype.pkl",
    output:
        geno = f"{GENO_BASEDIR}/all_individuals.npy",
        meta = f"{GENO_BASEDIR}/meta.pkl",
    params:
        outdir = GENO_BASEDIR,
        subset_snps = VAE_CFG.get("subset_snps", 10000),
        subset_mode = VAE_CFG.get("subset_mode", "random"),

    threads: 1
    shell:
        r"""
        python "{BUILD_VAE_INPUTS}" \
            --tree {input.tree} \
            --phenotype {input.pheno} \
            --outdir {params.outdir} \
            --subset-snps {params.subset_snps} \
            --subset-mode {params.subset_mode}
        """

##############################################################################
# RULE train_vae – train genotype VAE                                       #
##############################################################################
rule train_vae:
    input:
        geno = f"{GENO_BASEDIR}/all_individuals.npy",
        meta = f"{GENO_BASEDIR}/meta.pkl",
        model_cfg = "config_files/vae_model_config.yaml"
    output:
        model     = f"{VAE_BASEDIR}/{{param_id}}/genotype_vae.pt",
        losses    = f"{VAE_BASEDIR}/{{param_id}}/vae_losses.csv",
        loss_plot = f"{VAE_BASEDIR}/{{param_id}}/vae_loss_curves.png",
        pca_plot  = f"{VAE_BASEDIR}/{{param_id}}/latent_pca_by_population.png",
    params:
        arch       = lambda wc: parse_param_id(wc.param_id)["arch"],
        latent_dim = lambda wc: parse_param_id(wc.param_id)["latent_dim"],
        beta       = lambda wc: parse_param_id(wc.param_id)["beta"],

        # MLP-only
        hidden_dim = lambda wc: parse_param_id(wc.param_id).get("hidden_dim", ""),
        depth      = lambda wc: parse_param_id(wc.param_id).get("depth", ""),

        # CNN-only (stringify nicely)
        channels   = lambda wc: "-".join(map(str, parse_param_id(wc.param_id).get("channels", []))),
        kernel     = lambda wc: parse_param_id(wc.param_id).get("kernel_size", ""),
        dropout    = lambda wc: parse_param_id(wc.param_id).get("dropout", ""),
    threads: 1
    resources:
        gpus = 1
    shell:
        r"""
        if [ "{params.arch}" = "mlp" ]; then
            python "{TRAIN_VAE_SCRIPT}" \
                --genotype {input.geno} \
                --meta {input.meta} \
                --outdir "{VAE_BASEDIR}/{wildcards.param_id}" \
                --model-config {input.model_cfg} \
                --arch {params.arch} \
                --latent-dim {params.latent_dim} \
                --beta {params.beta} \
                --hidden-dim {params.hidden_dim} \
                --depth {params.depth}
        else
            python "{TRAIN_VAE_SCRIPT}" \
                --genotype {input.geno} \
                --meta {input.meta} \
                --outdir "{VAE_BASEDIR}/{wildcards.param_id}" \
                --model-config {input.model_cfg} \
                --arch {params.arch} \
                --latent-dim {params.latent_dim} \
                --beta {params.beta} \
                --channels "{params.channels}" \
                --kernel-size {params.kernel} \
                --dropout {params.dropout}
        fi
        """



##############################################################################
# RULE evaluate_vae_ld – Does the VAE preserve LD structure?                 #
##############################################################################
rule evaluate_vae_ld:
    input:
        geno  = f"{GENO_BASEDIR}/all_individuals.npy",
        meta  = f"{GENO_BASEDIR}/meta.pkl",
        model = f"{VAE_BASEDIR}/{{param_id}}/genotype_vae.pt",
        config_file = VAE_MODEL_CFG
    output:
        summary   = f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_comparison_summary.txt",
        scatter   = f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_scatter_orig_vs_recon.png",
        diff_hist = f"{VAE_BASEDIR}/{{param_id}}/ld_eval/ld_difference_hist.png",
    params:
        latent_dim = lambda wildcards: parse_param_id(wildcards.param_id)["latent_dim"],
        arch       = lambda wildcards: parse_param_id(wildcards.param_id)["arch"],
        beta       = lambda wildcards: parse_param_id(wildcards.param_id)["beta"],
        hidden_dim = lambda wc: parse_param_id(wc.param_id).get("hidden_dim", 512),
        depth      = lambda wc: parse_param_id(wc.param_id).get("depth", 6),
        channels   = lambda wc: ",".join(map(str, parse_param_id(wc.param_id).get("channels", [32, 64, 128]))),
        kernel_size = lambda wc: parse_param_id(wc.param_id).get("kernel_size", 5),
        dropout    = lambda wc: parse_param_id(wc.param_id).get("dropout", 0.0),
        use_batchnorm = lambda wc: "1",  # Default to True (most models use batchnorm)
    threads: 1
    resources:
        gpus = 1
    shell:
        r"""
        python snakemake_scripts/evaluate_vae_ld.py \
            --genotype {input.geno} \
            --meta {input.meta} \
            --model {input.model} \
            --latent-dim {params.latent_dim} \
            --hidden-dim {params.hidden_dim} \
            --depth {params.depth} \
            --beta {params.beta} \
            --arch {params.arch} \
            --channels {params.channels} \
            --kernel-size {params.kernel_size} \
            --dropout {params.dropout} \
            --use-batchnorm {params.use_batchnorm} \
            --outdir "{VAE_BASEDIR}/{wildcards.param_id}/ld_eval" \
            --max-snps 5000 \
            --seed 42
        """

