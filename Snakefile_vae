import json
import yaml
from pathlib import Path
from snakemake.io import protected
from itertools import product
import re

SIM_SCRIPT          = "snakemake_scripts/simulation.py"
BUILD_VAE_INPUTS    = "snakemake_scripts/build_genotypes_for_vae.py"
TRAIN_VAE_SCRIPT    = "snakemake_scripts/train_genotype_vae.py"

# Separate config for the VAE experiment (lots of CEU/YRI samples)
EXP_CFG = "config_files/experiment_config_vae.json"
VAE_MODEL_CFG = "config_files/vae_model_config.yaml"

CFG   = json.loads(Path(EXP_CFG).read_text())
VAE_CFG = yaml.safe_load(Path(VAE_MODEL_CFG).read_text())
MODEL = CFG["demographic_model"]

# Here we’ll just do one sid and one rep for the VAE
NUM_GRID = int(CFG.get("num_draws", 1))
REPS     = int(CFG.get("num_replicates", 1))

SID_RANGE = range(NUM_GRID)
REP_RANGE = range(REPS)

# Grid parameters for hyperparameter search
ARCH = VAE_CFG["model"]["arch"]
LATENT_DIMS = VAE_CFG["model"]["latent_dim_grid"]

if ARCH == "mlp":
    HIDDEN_DIMS = VAE_CFG["model"]["mlp"]["hidden_dim_grid"] 
    DEPTHS = VAE_CFG["model"]["mlp"]["depth_grid"]
elif ARCH == "cnn":
    # For CNN, we'll use channel configurations instead of hidden_dims
    CHANNEL_CONFIGS = VAE_CFG["model"]["cnn"]["channels_grid"]
    KERNEL_SIZES = VAE_CFG["model"]["cnn"]["kernel_size_grid"]
    DROPOUTS = VAE_CFG["model"]["cnn"]["dropout_grid"]
else:
    raise ValueError(f"Unknown architecture: {ARCH}")

BETAS = VAE_CFG["training"]["beta_grid"]

# Generate all parameter combinations based on architecture
if ARCH == "mlp":
    PARAM_COMBINATIONS = list(product(LATENT_DIMS, HIDDEN_DIMS, DEPTHS, BETAS))
    PARAM_IDS = [f"mlp_ld{ld}_h{hd}_d{d}_b{str(b).replace('.', 'p')}" 
                 for ld, hd, d, b in PARAM_COMBINATIONS]
elif ARCH == "cnn":
    PARAM_COMBINATIONS = list(product(LATENT_DIMS, CHANNEL_CONFIGS, KERNEL_SIZES, DROPOUTS, BETAS))
    PARAM_IDS = [f"cnn_ld{ld}_ch{'-'.join(map(str, ch))}_k{ks}_do{str(dr).replace('.', 'p')}_b{str(b).replace('.', 'p')}" 
                 for ld, ch, ks, dr, b in PARAM_COMBINATIONS]

# Helper function to parse parameter ID back to values
def parse_param_id(param_id: str) -> dict:
    # MLP: mlp_ld32_h512_d6_b0p1
    m = re.match(r"mlp_ld(\d+)_h(\d+)_d(\d+)_b([0-9ep\-]+)$", param_id)
    if m:
        beta_str = m.group(4).replace('p', '.')
        return {
            "arch": "mlp",
            "latent_dim": int(m.group(1)),
            "hidden_dim": int(m.group(2)),
            "depth": int(m.group(3)),
            "beta": float(beta_str),
        }

    # CNN: cnn_ld32_ch32-64-128-256_k7_do0p1_b0p1
    m = re.match(r"cnn_ld(\d+)_ch([\d\-]+)_k(\d+)_do([0-9ep\-]+)_b([0-9ep\-]+)$", param_id)
    if m:
        ch = tuple(int(x) for x in m.group(2).split("-"))
        dropout_str = m.group(4).replace('p', '.')
        beta_str = m.group(5).replace('p', '.')
        return {
            "arch": "cnn",
            "latent_dim": int(m.group(1)),
            "channels": ch,
            "kernel_size": int(m.group(3)),
            "dropout": float(dropout_str),
            "beta": float(beta_str),
        }

    raise ValueError(f"Unrecognized param_id format: {param_id}")

# Directories for this VAE experiment
SIM_BASEDIR   = f"experiments/{MODEL}/vae_sims"
GENO_BASEDIR  = f"experiments/{MODEL}/genotypes"
VAE_BASEDIR   = f"experiments/{MODEL}/vae"

# Save the config for record-keeping
config_path = Path(f"{SIM_BASEDIR}/config.json")
config_path.parent.mkdir(parents=True, exist_ok=True)
config_path.write_text(json.dumps(CFG, indent=4))

##############################################################################
# RULE all – final targets                                                   #
##############################################################################
rule all:
